# ===============================================================
# Environment Files (do not commit sensitive credentials)
# ===============================================================
.env
!.env.template

# ===============================================================
# Data Files (raw, processed, outputs)
# ===============================================================
data/
outputs/

# ===============================================================
# Raw Data Files (do not commit large data files)
# ======================================================
data/raw/*.csv
data/raw/*.parquet
data/raw/*.nc
data/raw/*.tif
data/raw/*.json

# ===============================================================
# Python Cache and Logs
# ===============================================================
__pycache__/
*.pyc
*.pyo
*.log
.pytest_cache/
logs/

# ===============================================================
# Admin/Utility Scripts (project management automation)
# ===============================================================
*.ps1
